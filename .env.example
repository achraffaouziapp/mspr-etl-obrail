# Paramètres de connexion à PostgreSQL.
# Ces variables sont utilisées par l'API FastAPI, le dashboard Streamlit
# et les scripts Python qui doivent se connecter à la base de données.

# Adresse du serveur PostgreSQL.
# En local avec Docker, on utilise localhost.
DB_HOST=localhost

# Port PostgreSQL exposé par Docker.
DB_PORT=5432

# Nom de la base de données du projet ObRail.
DB_NAME=obrail

# Utilisateur PostgreSQL utilisé par les scripts et l'API.
DB_USER=postgres

# Mot de passe PostgreSQL associé à l'utilisateur.
# Pour un vrai environnement de production, il faudrait utiliser un mot de passe plus robuste.
DB_PASSWORD=postgres
